{
  "name": "@zskarte/server",
  "version": "5.1.1",
  "private": true,
  "description": "Backend for zskarte",
  "license": "MIT",
  "author": {
    "name": "ZSKarte Team"
  },
  "config": {
    "executableName": "zskarte-server"
  },
  "scripts": {
    "dev": "strapi develop",
    "start": "strapi start",
    "build": "strapi build",
    "export:user-role": "config-sync export --yes --type user-role",
    "prebuild:webpack": "cd ../.. && npm run prepare-bundle",
    "build:webpack": "npx webpack --config bundle_files/webpack.config.mjs",
    "prebuild:sea": "cd ../.. && npm run prepare-bundle exec",
    "build:sea": "cd ../.. && npm run bundle-sea && npm run inject-sea",
    "postbuild:sea": "cd ../.. && npm run zip-release",
    "build:all": "npm run build && npm run build:webpack && npm run build:sea",
    "start:webpack": "cd bundled/ && ./startWebpack.sh",
    "start:sea": "cd exec/ && ./startServer.sh",
    "setup:sea": "cd exec/ && ./startServer.sh --setup",
    "regenerate": "strapi ts:generate-types",
    "export": "config-sync export --yes --type user-role",
    "strapi": "strapi"
  },
  "dependencies": {
    "@strapi/plugin-users-permissions": "5.33.2",
    "@strapi/strapi": "5.33.2",
    "immer": "^10.2.0",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2",
    "socket.io": "^4.8.3",
    "strapi-plugin-config-sync": "^3.1.2",
    "strapi-provider-upload-azure-storage": "^3.5.0",
    "styled-components": "^6.1.19",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.21",
    "node-loader": "^2.1.0",
    "null-loader": "^4.0.1",
    "postject": "^1.0.0-alpha.6",
    "typescript": "^5",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1"
  },
  "optionalDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "better-sqlite3": "^12.5.0",
    "pg": "^8.16.3"
  }
}
