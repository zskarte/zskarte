{
  "name": "@zskarte/app",
  "version": "5.1.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ng:serve": "ng serve --port 4300 --host 0.0.0.0",
    "ng:serve:dev": "ng serve --port 4300 --host 0.0.0.0 --configuration development",
    "ng:serve:prod": "ng serve --port 4300 --host 0.0.0.0 --configuration production",
    "ng:serve:e2e": "npm-run-all -p ng:serve:dev wait",
    "ng:build:prod": "ng build --configuration production",
    "ng:build:dev": "ng build --configuration development",
    "build": "run-p ng:build:prod",
    "start": "run-p ng:serve",
    "start:dev": "run-p ng:serve:dev",
    "test:e2e": "playwright test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.6",
