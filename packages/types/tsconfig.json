{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "composite": true,
    "declaration": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["**/*.ts"]
}